# MyYado local environment template.
# Copy this file to .env, then fill every required value before running yarn dev.
# Public client variables must use the REACT_APP_ prefix and are visible in browser bundles.
# Do not commit .env or put real secrets in this example file.

# Required. Sharetribe Marketplace API client ID; UUID format from Sharetribe Console > Build > Applications.
REACT_APP_SHARETRIBE_SDK_CLIENT_ID=

# Required. Sharetribe Marketplace API client secret paired with the client ID; secret string from Sharetribe Console.
SHARETRIBE_SDK_CLIENT_SECRET=

# Required. Stripe publishable key used by the browser for payment setup; format pk_test_... locally.
REACT_APP_STRIPE_PUBLISHABLE_KEY=

# Required for map search unless Google Maps is configured; Mapbox public access token format pk....
REACT_APP_MAPBOX_ACCESS_TOKEN=

# Required. Canonical local root URL without a trailing slash; local format http://localhost:3000.
REACT_APP_MARKETPLACE_ROOT_URL=http://localhost:3000

# Required. Marketplace display name used in metadata and fallback copy; plain text, e.g. MyYado.
REACT_APP_MARKETPLACE_NAME=

# Required. Runtime environment label for client/server behavior; local value is development.
REACT_APP_ENV=development

# Required. Content Security Policy mode; use report locally, block in production.
REACT_APP_CSP=report

# Optional. Sharetribe API base URL override; absolute URL, leave blank for Sharetribe production API.
REACT_APP_SHARETRIBE_SDK_BASE_URL=

# Optional. Sharetribe Asset Delivery CDN base URL override; absolute URL, leave blank for default CDN.
REACT_APP_SHARETRIBE_SDK_ASSET_CDN_BASE_URL=

# Optional. Sharetribe SDK transit logging; boolean string true or false.
REACT_APP_SHARETRIBE_SDK_TRANSIT_VERBOSE=false

# Optional. Whether generated Sharetribe URLs should use SSL; boolean string true or false.
REACT_APP_SHARETRIBE_USING_SSL=false

# Optional. Local API server port consumed by yarn dev; integer, default is set by package.json to 3500.
REACT_APP_DEV_API_SERVER_PORT=3500

# Optional. Google Maps browser API key if using Google Maps instead of Mapbox; key string from Google Cloud.
REACT_APP_GOOGLE_MAPS_API_KEY=

# Optional. Facebook app ID for social login and share metadata; numeric app ID from Meta developer settings.
REACT_APP_FACEBOOK_APP_ID=

# Optional secret. Facebook app secret for server-side OAuth callbacks; secret string from Meta developer settings.
FACEBOOK_APP_SECRET=

# Optional. Google OAuth client ID for social login; client ID ending in .apps.googleusercontent.com.
REACT_APP_GOOGLE_CLIENT_ID=

# Optional secret. Google OAuth client secret for server-side OAuth callbacks; secret string from Google Cloud.
GOOGLE_CLIENT_SECRET=

# Optional. Sentry DSN for browser and server error reporting; DSN URL, leave blank to disable locally.
REACT_APP_SENTRY_DSN=

# Optional. GA4 measurement ID for analytics; format G-XXXXXXXXXX.
REACT_APP_GOOGLE_ANALYTICS_ID=

# Optional. Plausible domains for analytics; comma-separated hostnames, e.g. example.com,www.example.com.
REACT_APP_PLAUSIBLE_DOMAINS=

# Optional. Production/server port for yarn start; integer, usually provided by the host platform.
PORT=4000

# Optional. Force HTTP-to-HTTPS redirects on the server; boolean string true or false.
SERVER_SHARETRIBE_REDIRECT_SSL=false

# Optional. Express trust proxy setting for hosted environments; boolean string true or false.
SERVER_SHARETRIBE_TRUST_PROXY=false

# Optional. Sharetribe Console base URL for login-as links; absolute URL, leave blank for Sharetribe Console.
SERVER_SHARETRIBE_CONSOLE_URL=

# Optional. Basic auth username for protecting non-public deployments; plain string.
BASIC_AUTH_USERNAME=

# Optional secret. Basic auth password for protecting non-public deployments; secret string.
BASIC_AUTH_PASSWORD=

# Optional secret. RSA private key for OIDC well-known endpoints; PEM string with escaped newlines if single-line.
RSA_PRIVATE_KEY=

# Optional. RSA public key for OIDC well-known endpoints; PEM string with escaped newlines if single-line.
RSA_PUBLIC_KEY=

# Optional. Key identifier for OIDC well-known endpoints; stable string matching the RSA key pair.
KEY_ID=

# Optional. Maximum outbound Sharetribe SDK sockets; integer, leave blank for SDK default.
MAX_SOCKETS=

# Optional. SDK proxy cache TTL for alias asset calls; seconds as integer, 0 disables alias caching.
TTL=0

# Optional. SDK proxy cache TTL for versioned asset calls; seconds as integer, default is 86400.
TTL_ASSETS_BY_VERSION=86400

# Optional. Disable sitemap generation; boolean string true or false.
SITEMAP_DISABLED=false

# Optional. Enable verbose server logging; boolean string true or false.
VERBOSE=false

# Optional. Skip SSR data loading during local debugging; boolean string true or false.
PREVENT_DATA_LOADING_IN_SSR=false
